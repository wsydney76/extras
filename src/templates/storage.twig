{% import '@extras/_macros/storage.twig' as storage %}

{% requireAdmin %}

{% if not craft.app.config.general.devMode %}
    {% exit 403 %}
{% endif %}


{% set element = craft.app.elements.elementById(craft.app.request.param('id')) %}

{% if not element %}
    {% exit 404 %}
{% endif %}


{{ storage.displayAll(element) }}